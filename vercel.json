{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/categorize.ts": { "maxDuration": 60 },
    "api/extract.ts":    { "maxDuration": 60 },
    "api/ask.ts":        { "maxDuration": 60 }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/"
    }
  ]
}
